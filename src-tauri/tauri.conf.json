{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skills-manage",
  "version": "0.9.3",
  "identifier": "com.iamzhihuix.skillsmanage",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:24200",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "skills-manage",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "28d41c68-f4a4-5134-b959-34babea58f7f"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": []
    }
  }
}
